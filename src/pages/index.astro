---
import '@fontsource/geist';
import '@fontsource/dynapuff';

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

import { Highlighter } from '@/components/ui/highlighter';

import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="flex flex-col items-center mx-auto pt-16 mt-15 md:mt-[88px] w-full px-9 md:px-13 lg:px-16 max-w-7xl">
      <div class="text-center">
        <h1 class="text-7xl font-medium py-6 font-[DynaPuff]">
          <span>The <Highlighter client:load action="highlight" color="#FF9800">First</Highlighter> Choice for</span>
          <span class="block">Making Games in Python</span>
        </h1>
        <p class="text-xl text-balance">
          Pygame: Community Edition is a drop-in replacement with modern performance and features maintained by the
          original team from the Pygame Organization.
        </p>
      </div>
      <div class="my-6 rounded-3xl overflow-hidden relative">
        <video class="w-full block" autoplay loop muted>
          <source src="yawnoc_dafluffypotato.mp4" type="video/mp4" />
        </video>
        <div class="absolute bottom-2 right-3 text-white text-sm bg-black/50 px-2 py-1 rounded-lg">
          "Yawnoc" by DaFluffyPotato
        </div>
      </div>
    </main>
  </body>
</html>
